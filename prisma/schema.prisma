// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL") // uses connection pooling
  directUrl = env("POSTGRES_URL_NON_POOLING") // uses a direct connection
}

// Simple workout session model matching your Google Sheets structure
model WorkoutSession {
  id               String    @id @default(cuid())
  date             DateTime
  source           String // "Peloton", "Cannondale", "Tonal", etc.
  activity         String // "Cycling", "Weight Lifting", etc.
  minutes          Int // Duration in minutes
  miles            Float? // Distance for cardio activities
  weightLifted     Float? // Total weight lifted for strength training
  notes            String?
  pelotonWorkoutId String?   @unique // Peloton workout ID for dedup
  tonalWorkoutId   String?   @unique // Tonal workout ID for dedup
  // Soft-delete (F-06): writes that go through the API set deletedAt
  // instead of removing the row, so an audit trail + recovery is possible.
  deletedAt        DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([date])
  @@index([source, date])
  @@index([deletedAt])
  @@map("workout_sessions")
}

model PelotonCredential {
  id           String   @id @default(cuid())
  userId       String   @unique // Peloton user ID
  sessionId    String // Session cookie (encrypted at rest — see src/lib/crypto.ts)
  accessToken  String? // OAuth access token (encrypted at rest)
  refreshToken String? // OAuth refresh token (encrypted at rest)
  expiresAt    Int? // Unix timestamp
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("peloton_credentials")
}

model TonalCredential {
  id           String   @id @default(cuid())
  userId       String   @unique // Tonal user ID from Auth0
  idToken      String   @db.Text // JWT id_token (encrypted at rest)
  accessToken  String?  @db.Text // Auth0 access_token (encrypted at rest)
  refreshToken String?  @db.Text // (encrypted at rest)
  expiresAt    Int? // Unix timestamp
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("tonal_credentials")
}

// Goal tracking for quarterly and annual targets
model Goal {
  id   String @id @default(cuid())
  name String
  year Int

  // Annual targets
  annualWeightTarget   Float // Total lbs for the year
  minutesPerSession    Int // Minutes per individual session
  weeklySessionsTarget Int // Sessions per week

  // Calculated fields (derived from above)
  weeklyMinutesTarget     Int // minutesPerSession * weeklySessionsTarget
  annualMinutesTarget     Int // weeklyMinutesTarget * 52
  quarterlyWeightTarget   Float // annualWeightTarget / 4
  quarterlyMinutesTarget  Int // annualMinutesTarget / 4
  quarterlySessionsTarget Int // weeklySessionsTarget * 13

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("goals")
}

// Monthly summaries (auto-calculated from workout sessions)
model MonthlySummary {
  id            String   @id @default(cuid())
  year          Int
  month         Int // 1-12
  totalMinutes  Int
  totalMiles    Float
  totalSessions Int
  averageWeight Float?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([year, month])
  @@map("monthly_summaries")
}

// Audit log (F-06) — every bearer-authed mutation, plus session mutations,
// records a row here so a leaked MCP_API_TOKEN leaves a trail.
model AuditLog {
  id        String   @id @default(cuid())
  // "session" for NextAuth users, "bearer" for MCP_API_TOKEN callers.
  authMode  String
  // Best-effort identity. For "session" this is the user email. For
  // "bearer" it is the constant string "mcp-pat".
  actor     String
  // Short action key: e.g. "workout.create", "workout.delete",
  // "peloton.sync", "tonal.disconnect".
  action    String
  // Route path, for cross-reference with logs.
  path      String
  // Caller IP from x-forwarded-for / x-real-ip, "unknown" otherwise.
  ip        String?
  // Free-form JSON details (input filters, result counts, target IDs).
  details   String   @db.Text
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([authMode, createdAt])
  @@map("audit_log")
}
